include README.md
include LICENSE
include requirements.txt
include requirements-conda.txt
include pyproject.toml
include environment.yml

# Include specifications
recursive-include specifications *.md

# Include test files
recursive-include test *.py
recursive-include test *.ipynb
recursive-include test *.json

# Include package files
recursive-include fairfluids *.py
recursive-include fairfluids *.json
recursive-include fairfluids *.xml

# Include documentation
include *.md
include *.rst

# Exclude development files
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude .git*
global-exclude .DS_Store
global-exclude .coverage
global-exclude htmlcov/
global-exclude .pytest_cache/
global-exclude .mypy_cache/
global-exclude *.egg-info/
global-exclude build/
global-exclude dist/
